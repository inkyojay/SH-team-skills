# ============================================
# Team Skills 환경변수 설정
# ============================================
# 이 파일을 복사하여 .envrc 로 저장하세요:
#   cp .envrc.example .envrc
#
# 그 후 각 API 키를 발급받아 입력하세요.
# 모든 키가 필요한 것은 아닙니다 — 사용하는 스킬에 맞는 키만 설정하면 됩니다.
# ============================================

# ── 1. Google Gemini (필수 — 대부분의 스킬에서 사용) ──────────
# 발급: https://aistudio.google.com/apikey
# 사용: 이미지 변환, 카드뉴스, 릴스 편집, 블로그 작성 등
export GEMINI_API_KEY="여기에_입력"
export GOOGLE_AI_API_KEY="$GEMINI_API_KEY"
export GOOGLE_API_KEY="$GEMINI_API_KEY"

# ── 2. 네이버 검색광고 API (키워드 분석 스킬용) ──────────────
# 발급: https://searchad.naver.com → 도구 → API 사용 관리
# 사용: keyword-trend, keyword-optimizer, new-product-planner, naver-blog-seo-writer
export NAVER_API_KEY="여기에_입력"
export NAVER_SECRET_KEY="여기에_입력"
export NAVER_CUSTOMER_ID="여기에_입력"

# ── 3. 네이버 Open API (검색/쇼핑 분석용) ────────────────────
# 발급: https://developers.naver.com → 애플리케이션 등록
# 사용: new-product-planner (쇼핑 분석), naver-blog-seo-writer
export NAVER_CLIENT_ID="여기에_입력"
export NAVER_CLIENT_SECRET="여기에_입력"

# ── 4. 선택 — 사용하는 스킬에 따라 설정 ─────────────────────

# RapidAPI (인스타그램 체험단 검색)
# 발급: https://rapidapi.com
# export RAPIDAPI_KEY="여기에_입력"

# Apify (웹 스크래핑)
# 발급: https://apify.com → Settings → API
# export APIFY_TOKEN="여기에_입력"

# Anthropic (대시보드용)
# 발급: https://console.anthropic.com
# export ANTHROPIC_API_KEY="여기에_입력"

# Mapbox (영상 지도 효과)
# 발급: https://account.mapbox.com
# export REMOTION_MAPBOX_TOKEN="여기에_입력"
